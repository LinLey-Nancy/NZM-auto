{
  "version": 2,
  "name": "example-gui-workflow",
  "target": {
    "title_pattern": "逆战：未来",
    "class_name": null
  },
  "settings": {
    "stop_on_error": true,
    "default_timeout_ms": 10000
  },
  "steps": [
    {
      "id": "find-document",
      "type": "template_match",
      "name": "识别文本文档",
      "template": "assets/resource/image/replace-with-document-template.png",
      "threshold": 0.8,
      "attempts": 3,
      "interval_ms": 500,
      "result_variable": "document"
    },
    {
      "id": "open-document",
      "type": "mouse_click",
      "name": "双击文本文档",
      "match_variable": "document",
      "button": "left",
      "count": 2,
      "interval_ms": 100
    },
    {
      "id": "wait-for-editor",
      "type": "wait",
      "name": "等待编辑器打开",
      "duration_ms": 1000
    },
    {
      "id": "type-marker",
      "type": "text_input",
      "name": "输入测试文本",
      "text": "NZM automation input verification",
      "strategy": "key_sequence",
      "interval_ms": 80
    },
    {
      "id": "save",
      "type": "key_press",
      "name": "保存文件",
      "key": "S",
      "modifiers": ["CTRL"]
    }
  ]
}
